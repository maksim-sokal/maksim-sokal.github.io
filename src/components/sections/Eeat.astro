---
import { Fingerprint } from "lucide-react";
import { ME_BIO, TRUST_FACTORS } from "../../data";
import GpgCopyButton from "../react/GpgCopyButton.tsx";
---

<section id="eeat" class="bg-brand-900/25 border border-[#1e293b]/40 rounded-2xl p-8 md:p-12 space-y-12">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
    <div class="lg:col-span-5 space-y-6">
      <span class="text-xs font-mono text-sky-400 uppercase tracking-widest block">04. My Framework</span>
      <h2 class="font-display font-medium text-3xl text-slate-100 tracking-tight leading-tight">Verification Pillars of Operational Authority</h2>
      <p class="text-slate-400 text-xs md:text-sm leading-relaxed font-sans">
        True authority in Web3 cannot be simulated. It exists purely in on-chain safety metrics, open source disclosure files, and cryptographic proof lines.
      </p>

      <div class="bg-[#090d16] p-4 border border-brand-800/40 rounded-xl space-y-3">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <Fingerprint class="w-4 h-4 text-sky-400" />
            <span class="text-[10px] uppercase font-mono tracking-wider text-slate-300">GPG Audit Signature Key</span>
          </div>
          <span class="text-[9px] text-emerald-400 font-mono bg-emerald-500/5 px-2 py-0.5 rounded border border-emerald-500/10">ECC SECP256K1</span>
        </div>
        
        <GpgCopyButton gpgKey={ME_BIO.gpgKey} client:visible />
      </div>
    </div>

    <div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-6">
      {TRUST_FACTORS.map((tf) => (
        <div key={tf.id} class="bg-brand-950/40 border border-[#1e293b]/30 p-5 rounded-xl space-y-3 flex flex-col justify-between">
          <div class="space-y-1">
            <span class="text-[10px] font-mono text-sky-400 uppercase tracking-widest block">{tf.title}</span>
            <span class="block text-3xl font-display font-medium text-slate-100 tracking-tight text-glow">
              {tf.metric}
            </span>
          </div>
          <p class="text-xs text-slate-400 leading-relaxed font-sans pt-2 border-t border-brand-800/20">
            {tf.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
