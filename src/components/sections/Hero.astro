---
import {
  Award, BookOpen, Linkedin, Globe, ArrowRight
} from "lucide-react";
import { ME_BIO } from "../../data";
---

<section id="hero" class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center pt-4">
  <div class="lg:col-span-7 space-y-8">
    <div class="inline-flex items-center gap-2 px-3 py-1 bg-sky-500/5 border border-sky-400/10 rounded-full">
      <span class="w-2 h-2 bg-emerald-400 rounded-full animate-ping"></span>
      <span class="text-[10px] uppercase font-mono tracking-widest text-sky-300">Active Economic Verification Guard</span>
    </div>

    <div class="space-y-4">
      <h1 class="font-display font-bold text-5xl md:text-7xl text-slate-100 tracking-tight leading-[0.95]">
        <span class="block text-slate-400 font-light text-3xl md:text-4xl mb-2 font-sans">Quantitative Protocol Analyst</span>
        Maksim Sokal
      </h1>
      <p class="font-display text-lg md:text-2xl text-sky-300/80 font-normal tracking-wide">
        Defi Analyst & Invariant Auditor
      </p>

      <div class="flex flex-wrap gap-2.5 pt-2">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-brand-900/80 border border-sky-500/10 rounded-lg text-xs text-sky-300 hover:border-sky-400/30 transition-colors select-none">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-sky-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-sky-500"></span>
          </span>
          <span class="font-mono text-[10px] uppercase tracking-wider">DefiLlama Affiliated</span>
        </span>

        <a href="https://asterdexhub.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-brand-900/80 border border-slate-800 rounded-lg text-xs text-slate-300 hover:border-[#1e293b] hover:text-[#38bdf8] transition-all duration-300 group">
          <Award class="w-3.5 h-3.5 text-indigo-400 group-hover:scale-105 transition-transform" />
          <span class="font-mono text-[10px] uppercase tracking-wider">Reviewer @ Aster DEX Hub</span>
        </a>

        <a href="https://en.wikipedia.org/wiki/Moscow_Institute_of_Physics_and_Technology" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-brand-900/80 border border-slate-800 rounded-lg text-xs text-slate-300 hover:border-[#1e293b] hover:text-[#10b981] transition-all duration-300 group">
          <BookOpen class="w-3.5 h-3.5 text-emerald-400 group-hover:scale-105 transition-transform" />
          <span class="font-mono text-[10px] uppercase tracking-wider">MSc, MIPT Lab</span>
        </a>

        <a href="https://by.linkedin.com/in/maksim-sokal" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-brand-900/80 border border-slate-800 rounded-lg text-xs text-slate-300 hover:border-sky-500/20 hover:text-sky-300 transition-all duration-300 group">
          <Linkedin class="w-3.5 h-3.5 text-sky-400 group-hover:scale-110 transition-transform" />
          <span class="font-mono text-[10px] uppercase tracking-wider">LinkedIn</span>
        </a>

        <a href="https://featured.com/p/maksim-sokal" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-brand-900/80 border border-slate-800 rounded-lg text-xs text-slate-300 hover:border-indigo-500/20 hover:text-indigo-300 transition-all duration-300 group">
          <Globe class="w-3.5 h-3.5 text-indigo-400 group-hover:scale-110 transition-transform" />
          <span class="font-mono text-[10px] uppercase tracking-wider font-semibold">Featured</span>
        </a>
      </div>
    </div>

    <p class="text-slate-400 max-w-xl text-sm md:text-base leading-relaxed font-sans">
      I secure Web3 ecosystems utilizing discrete mathematical validation. I audit code flows, model liquidations under stress, and safeguard contract state boundaries to fortify protocol mechanics against high-end exploits.
    </p>

    <div class="grid grid-cols-3 gap-6 pt-4 border-t border-brand-800/40 max-w-lg">
      <div>
        <span class="block text-xl font-mono text-slate-100 font-semibold">$2.1B+</span>
        <span class="text-[10px] font-mono text-slate-400 uppercase tracking-widest">TVL Protected</span>
      </div>
      <div>
        <span class="block text-xl font-mono text-slate-100 font-semibold">0</span>
        <span class="text-[10px] font-mono text-slate-400 uppercase tracking-widest">Exploits Post-Audit</span>
      </div>
      <div>
        <span class="block text-xl font-mono text-slate-100 font-semibold">450+</span>
        <span class="text-[10px] font-mono text-slate-400 uppercase tracking-widest">Asserts Written</span>
      </div>
    </div>

    <div class="flex flex-wrap gap-4 pt-4">
      <a href="#experience" class="bg-sky-500/10 hover:bg-sky-500/20 border border-sky-400/40 hover:border-sky-400 text-sky-300 text-xs font-mono uppercase tracking-widest px-6 py-3.5 rounded-xl transition-all duration-300 cursor-pointer flex items-center gap-2 shadow-lg shadow-sky-500/5 group">
        <span>Explore Audit Log</span>
        <ArrowRight class="w-4 h-4 text-sky-400 group-hover:translate-x-1 transition-transform" />
      </a>
    </div>
  </div>

  <div class="lg:col-span-5 flex justify-center">
    <div class="relative w-full max-w-[340px]">
      <div class="absolute -top-6 -left-4 font-mono text-[9px] text-emerald-400 tracking-wider z-30 select-none bg-brand-950/70 backdrop-blur-md px-2 py-0.5 rounded border border-emerald-400/20 flex items-center gap-1">
        <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
        AUDITOR_PROFILE: M.S.
      </div>
      <div class="aspect-[490/642] rounded-2xl overflow-hidden shadow-2xl group border border-[#1e293b]/50">
        <div class="absolute inset-0 border border-sky-500/10 rounded-2xl z-20 pointer-events-none"></div>
        <div class="absolute top-2 left-2 right-2 bottom-2 border border-[#1e293b]/45 rounded-xl z-20 pointer-events-none"></div>

        <div class="absolute bottom-4 right-4 font-mono text-[9px] text-emerald-400 tracking-wider z-20 select-none bg-brand-950/70 backdrop-blur-md px-2 py-0.5 rounded border border-emerald-400/20 flex items-center gap-1">
          <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
          KEY_VERIFIED
        </div>

        <img
          src="/images/Maksim-Sokal.webp"
          alt="Maksim Sokal - DeFi Risk Analyst Portrait"
          class="w-full h-full object-cover grayscale brightness-95 group-hover:grayscale-0 group-hover:scale-[1.02] transition-all duration-700 z-10 relative"
          referrerpolicy="no-referrer"
        />
      </div>

      <div class="absolute -bottom-6 -right-4 w-40 bg-brand-900/90 border border-[#1e293b]/80 p-4 rounded-xl shadow-xl z-30 backdrop-blur-md hidden sm:block">
        <span class="block text-[9px] font-mono text-indigo-400 uppercase tracking-wider mb-1">Audit Signature</span>
        <p class="text-xs font-sans text-slate-300 font-semibold leading-snug">Autonomous Smart Contract Asserts</p>
      </div>
    </div>
  </div>
</section>
