---
import BaseLayout from '../layouts/BaseLayout.astro';
import BackgroundDecor from '../components/sections/BackgroundDecor.astro';
import Header from '../components/sections/Header.astro';
import Hero from '../components/sections/Hero.astro';
import About from '../components/sections/About.astro';
import Experience from '../components/sections/Experience.astro';
import Methodology from '../components/sections/Methodology.astro';
import Eeat from '../components/sections/Eeat.astro';
import Transparency from '../components/sections/Transparency.astro';
import Contact from '../components/sections/Contact.astro';
import Footer from '../components/sections/Footer.astro';
---
<BaseLayout>
  <BackgroundDecor />
  <Header />
  <main class="relative z-10 max-w-7xl mx-auto px-6 py-12 md:py-24 space-y-32">
    <Hero />
    <About />
    <Experience />
    <Methodology />
    <Eeat />
    <Transparency />
    <Contact />
  </main>
  <Footer />
</BaseLayout>
